# ─── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── KCB Buni (M-Pesa) ──────────────────────────────────────
BUNI_ENV=sandbox
BUNI_CLIENT_ID=
BUNI_CLIENT_SECRET=
BUNI_SHORTCODE=
BUNI_PASSKEY=

# ─── Stanbic PesaLink ────────────────────────────────────────
STANBIC_ENV=sandbox
STANBIC_CLIENT_ID=
STANBIC_CLIENT_SECRET=
STANBIC_ACCOUNT_NO=

# ─── QuickBooks Online ───────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/accounting-sync/oauth/callback/quickbooks
QB_ENV=sandbox
QB_WEBHOOK_VERIFIER_TOKEN=

# ─── Zoho Books ──────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/accounting-sync/oauth/callback/zoho

# ─── Sync Engine ─────────────────────────────────────────────
TOKEN_ENCRYPT_KEY=your-32-char-aes-256-key-here-123
APP_URL=https://your-app.vercel.app
CRON_SECRET=your-random-cron-secret-here

# ─── Supabase Edge (auto-injected, do not set manually) ──────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
